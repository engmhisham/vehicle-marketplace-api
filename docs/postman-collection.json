{
  "info": {
    "name": "Vehicle Marketplace API",
    "description": "Complete API collection for Vehicle Marketplace with Real-time Auctions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"+201234567890\", \"firstName\": \"Ahmed\", \"lastName\": \"Mohamed\", \"role\": \"BUYER\"}"
            }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/verify-otp",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"+201234567890\", \"code\": \"123456\"}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const res = pm.response.json();", "if (res.data && res.data.accessToken) {", "  pm.collectionVariables.set('accessToken', res.data.accessToken);", "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);", "}"]
            }
          }]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"phone\": \"+201000000001\", \"password\": \"admin123\"}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"{{refreshToken}}\"}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\": \"{{refreshToken}}\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/me",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"firstName\": \"Ahmed\", \"lastName\": \"Updated\", \"email\": \"ahmed@example.com\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        {
          "name": "List Vehicles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vehicles?page=1&limit=20"
          }
        },
        {
          "name": "Get Vehicle",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vehicles/:id"
          }
        },
        {
          "name": "Create Vehicle",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/vehicles",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"make\": \"Toyota\", \"model\": \"Camry\", \"year\": 2023, \"price\": 25000, \"mileage\": 15000, \"condition\": \"USED\", \"fuelType\": \"GASOLINE\", \"transmission\": \"AUTOMATIC\", \"color\": \"White\", \"description\": \"Well maintained\", \"location\": \"Cairo, Egypt\"}"
            }
          }
        },
        {
          "name": "Filter Vehicles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/vehicles?make=Toyota&priceMin=10000&priceMax=50000&yearMin=2020"
          }
        },
        {
          "name": "Search Vehicles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/search/vehicles?q=toyota camry"
          }
        }
      ]
    },
    {
      "name": "Auctions",
      "item": [
        {
          "name": "List Active Auctions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auctions?status=ACTIVE"
          }
        },
        {
          "name": "Get Auction",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auctions/:id"
          }
        },
        {
          "name": "Create Auction",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auctions",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"vehicleId\": \"VEHICLE_ID\", \"startingPrice\": 10000, \"bidIncrement\": 500, \"startTime\": \"2024-12-01T00:00:00Z\", \"endTime\": \"2024-12-07T23:59:59Z\"}"
            }
          }
        },
        {
          "name": "Place Bid",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auctions/:id/bid",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 15000}"
            }
          }
        },
        {
          "name": "Get Bid History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auctions/:id/bids"
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Get Rooms",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/chat/rooms",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]
          }
        },
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/chat/messages",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"recipientId\": \"USER_ID\", \"content\": \"Hello, is this still available?\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/wallet/balance",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]
          }
        },
        {
          "name": "Top Up",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/wallet/top-up",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 5000}"
            }
          }
        },
        {
          "name": "Request Withdrawal",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/wallet/withdraw",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{accessToken}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\": 1000, \"note\": \"Need funds\"}"
            }
          }
        },
        {
          "name": "Get Transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/wallet/transactions",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/dashboard",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]
          }
        },
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/users?page=1&limit=20",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]
          }
        },
        {
          "name": "Pending Vehicles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/vehicles/pending",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]
          }
        },
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/audit-logs",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/../health"
          }
        },
        {
          "name": "Readiness",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/../ready"
          }
        }
      ]
    }
  ]
}
