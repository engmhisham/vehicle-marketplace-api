# Application
NODE_ENV=development
PORT=3000
APP_NAME=vehicle-marketplace-api
API_PREFIX=api
API_VERSION=v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vehicle_marketplace?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRATION=7d

# OTP
OTP_EXPIRATION_MINUTES=5
OTP_LENGTH=6

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key
MINIO_BUCKET=vehicle-marketplace
MINIO_USE_SSL=false

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# Bull Queue (Redis)
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379

# Logging
LOG_LEVEL=debug

# Sentry (optional - add your DSN for error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
